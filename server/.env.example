# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paper_trading?schema=public"

# Express server port
PORT=3001

# JWT secret — change this in production!
JWT_SECRET="change-me-in-production"

# Alpaca API (free account at alpaca.markets — enables real-time prices)
# Without these, the app falls back to Yahoo Finance (~15 min delay)
ALPACA_API_KEY=""
ALPACA_API_SECRET=""
