{
  "buildCommand": "cd server && npx prisma generate && npx tsc && cd .. && cd client && npx vite build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install --workspaces",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "server/src/**"
    }
  },
  "crons": [
    { "path": "/api/cron/check-orders", "schedule": "0 6 * * *" },
    { "path": "/api/cron/check-alerts", "schedule": "0 12 * * *" },
    { "path": "/api/cron/refresh-market-data", "schedule": "0 14 * * *" },
    { "path": "/api/cron/warm-market-caps", "schedule": "0 13 * * *" }
  ]
}
